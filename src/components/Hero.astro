---
---
<section id="hero" class="relative w-full min-h-[100svh] lg:h-[100svh] flex flex-col lg:flex-row overflow-hidden bg-void">
  
  <!-- Left Side: Video (60% Desktop, 100% Mobile) -->
  <div class="relative w-full lg:w-[60%] h-[45vh] lg:h-full shrink-0">
    <video
      id="hero-video"
      class="w-full h-full object-cover opacity-0"
      autoplay
      muted
      loop
      playsinline
      poster="https://images.unsplash.com/photo-1511285560929-80b456fea0bc?q=80&w=2669&auto=format&fit=crop"
      preload="metadata"
    >
      <source src="https://assets.mixkit.co/videos/preview/mixkit-wedding-photographer-in-action-12349-large.mp4" type="video/mp4" />
    </video>
    
    <!-- Gradient Overlay to blend into the right panel -->
    <div class="absolute inset-0 bg-gradient-to-t lg:bg-gradient-to-r from-void/80 lg:from-transparent lg:via-void/40 to-void/100 lg:to-void pointer-events-none"></div>
  </div>

  <!-- Right Side: Content (40% Desktop, Full Mobile) -->
  <div class="right-panel w-full lg:w-[40%] flex-1 lg:h-full flex flex-col justify-center px-6 py-12 lg:py-0 lg:px-14 xl:px-20 relative z-10 opacity-0 translate-x-4 lg:translate-x-16">
    
    <div class="hero-content space-y-2 lg:space-y-3">
      <p class="hero-sub font-mono text-ember text-sm tracking-wide lowercase pt-2 lg:pt-0">
        est. kalyandurgam
      </p>
      
      <h1 class="font-display uppercase leading-[0.85] flex flex-col gap-1">
        <div class="relative overflow-hidden w-full pb-1">
          <span class="hero-title-word block text-[4.5rem] md:text-[5.5rem] lg:text-[6rem] xl:text-[7.5rem] tracking-tight text-cream">TARAK</span>
        </div>
        <div class="relative overflow-hidden w-full pb-1">
          <span class="hero-title-word block text-[4.5rem] md:text-[5.5rem] lg:text-[6rem] xl:text-[7.5rem] tracking-tight text-ember">STUDIO</span>
        </div>
      </h1>
      
      <p class="hero-sub font-body text-base lg:text-lg text-muted-film max-w-[280px] lg:max-w-sm pt-2 lg:pt-4">
        Where moments become masterpieces
      </p>
      
      <div class="hero-cta flex flex-wrap items-center gap-4 lg:gap-6 pt-8 pb-10 lg:pb-0 relative z-20">
        <a href="#contact" class="bg-ember text-charcoal font-semibold px-6 py-3 lg:px-8 lg:py-4 hover:bg-ember-glow transition-all duration-300 shadow-[0_0_20px_rgba(212,98,42,0.3)] hover:shadow-[0_0_30px_rgba(255,140,82,0.6)] text-sm lg:text-base border border-ember text-center">
          📸 Book Your Session
        </a>
        <a href="#portfolio" class="text-cream hover:text-ember transition-colors duration-300 font-medium flex items-center gap-2 group text-sm lg:text-base w-full sm:w-auto mt-2 sm:mt-0">
          <span class="text-ember group-hover:translate-x-1 transition-transform">▶</span> Watch Our Work
        </a>
      </div>
    </div>
    
    <!-- Pinned Contact Strip -->
    <div class="absolute lg:bottom-10 bottom-4 left-6 lg:left-14 xl:left-20 text-xs font-mono text-muted-film flex flex-col gap-2">
      <a href="tel:+918919619403" class="hover:text-cream transition-colors block">📞 +91 89196 19403</a>
      <span class="block">📍 Jaynagar, Kalyandurg, AP</span>
    </div>
  </div>
</section>
