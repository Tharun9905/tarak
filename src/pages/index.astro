<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Custom Utility for splitting text by characters safely
  function splitTextToChars(selector) {
    document.querySelectorAll(selector).forEach(el => {
      const text = el.innerText;
      let html = '';
      for (let char of text) {
        if(char === ' ') {
          html += '<span class="inline-block whitespace-pre">&nbsp;</span>';
        } else {
          html += `<span class="inline-block leading-none translate-y-full rotate-x-[-90deg] opacity-0 char-elem">${char}</span>`;
        }
      }
      el.innerHTML = html;
    });
    return Array.from(document.querySelectorAll(`${selector} .char-elem`));
  }

  // Orchestration Timeline
  const runAnimations = () => {
    // 1. Preloader logic
    const preloaderTL = gsap.timeline();
    const preloaderText = document.querySelector('.preloader-text');
    const preloaderBar = document.querySelector('.preloader-bar');
    const preloader = document.getElementById('preloader');
    
    // Check if hero already visible (visited skipping)
    if (!preloader || preloader.style.display === 'none') {
       startHero();
    } else {
      preloaderTL
        .to(preloaderText, { opacity: 1, letterSpacing: "0.2em", duration: 0.8, ease: "power2.out" })
        .to(preloaderBar, { scaleX: 1, duration: 1.2, ease: "power2.inOut" }, "-=0.2")
        .to(preloader, { opacity: 0, duration: 0.5, pointerEvents: "none", onComplete: () => {
           preloader.style.display = 'none';
           startHero();
        } });
    }

    function startHero() {
      // split characters inside hero
      const targetChars = splitTextToChars('.hero-title-word');
      
      const heroTL = gsap.timeline();
      heroTL
        .to(targetChars, {
           y: 0, 
           rotateX: 0, 
           opacity: 1,
           stagger: 0.05, 
           duration: 1.2, 
           ease: "expo.out"
        })
        .to(".hero-sub", { y: 0, opacity: 1, duration: 0.8 }, "-=1")
        .to(".right-panel", { x: 0, opacity: 1, duration: 1.2, ease: "power3.out" }, "-=1.2")
        .to("#hero-video", { opacity: 1, duration: 1.5 }, "-=0.8");
    }

    // 2. Statement animations
    gsap.to(".statement-text", {
      opacity: 1, y: 0, duration: 1,
      scrollTrigger: { trigger: "#statement", start: "top 70%" }
    });
    gsap.to(".statement-proof", {
      opacity: 1, y: 0, duration: 0.8, delay: 0.4,
      scrollTrigger: { trigger: "#statement", start: "top 70%" }
    });

    // 3. Horizontal Services Scroll
    if(window.innerWidth > 1024) {
      const track = document.querySelector('.services-track');
      if (track) {
        let scrollDist = track.scrollWidth - window.innerWidth;
        gsap.to(track, {
          x: -scrollDist,
          ease: "none",
          scrollTrigger: {
            trigger: "#services",
            pin: true,
            scrub: 1.2,
            end: () => "+=" + scrollDist
          }
        });
      }
    }

    // 4. Video Player Entrance
    gsap.from(".video-player-wrap", {
      scale: 0.88, opacity: 0, duration: 1.2, ease: "power4.out",
      scrollTrigger: { trigger: "#showreel", start: "top 70%" }
    });

    // 5. How It works timeline animation
    const steps = gsap.utils.toArray('.step-item');
    if (steps.length && window.innerWidth > 768) {
       const stepsTL = gsap.timeline({
         scrollTrigger: {
           trigger: "#how-it-works",
           pin: true,
           scrub: 1,
           start: "top top",
           end: "+=200%"
         }
       });
       
       steps.forEach((step, i) => {
         const delay = i * 0.5;
         const svgIcon = step.querySelector('.icon-svg');
         const pulse = step.querySelector('.pulse-ring');
         
         stepsTL
           .to(step, { opacity: 1, y: 0, duration: 0.5 }, delay)
           .to(".progress-line", { width: `${(i + 1) * 25}%`, duration: 0.5 }, delay)
           .to(svgIcon, { color: '#D4622A', duration: 0.2 }, delay)
           .to(pulse, { opacity: 1, scale: 1, duration: 0.3 }, delay)
           .to(pulse, { opacity: 0, scale: 1.5, duration: 0.3 }, delay + 0.3);
       });
    } else {
       // Mobile fallback
       gsap.to('.step-item', {
         opacity: 1, y: 0, stagger: 0.2,
         scrollTrigger: { trigger: "#how-it-works", start: "top 60%" }
       });
    }

    // 6. Number Counter
    ScrollTrigger.create({
      trigger: ".counter",
      start: "top 80%",
      onEnter: () => {
        gsap.to({ val: 0 }, {
          val: 1000, duration: 2.5, ease: "power3.out",
          onUpdate: function() {
            document.querySelector(".counter").textContent = Math.floor(this.targets()[0].val) + "+";
          }
        });
      },
      once: true
    });

    // 7. About Section Split Entrance
    gsap.to(".about-img-wrap", {
      x: 0, opacity: 1, duration: 1, ease: "power3.out",
      scrollTrigger: { trigger: "#about", start: "top 65%" }
    });
    gsap.to(".about-text-wrap", {
      x: 0, opacity: 1, duration: 1, delay: 0.2, ease: "power3.out",
      scrollTrigger: { trigger: "#about", start: "top 65%" }
    });

    // 8. Contact Section map drop
    gsap.to(".contact-map", {
      y: 0, opacity: 1, duration: 1, ease: "power3.out",
      scrollTrigger: { trigger: "#contact", start: "top 70%" }
    });
  };

  // Run on mount
  document.addEventListener('DOMContentLoaded', runAnimations);
  
  // Custom Cursor Logic
  if (window.innerWidth > 1024) {
    const cursor = document.querySelector(".custom-cursor");
    window.addEventListener("mousemove", (e) => {
      gsap.to(cursor, { x: e.clientX, y: e.clientY, duration: 0.15, ease: "power2.out" });
      if(cursor.style.opacity === '0' || cursor.style.opacity === '') {
         cursor.style.opacity = '1';
      }
    });

    document.querySelectorAll("a, button, .gallery-item, .service-card, .video-player-wrap").forEach(el => {
      el.addEventListener("mouseenter", () => gsap.to(cursor, { scale: 3, backgroundColor: 'transparent', border: '1px solid #D4622A', duration: 0.3 }));
      el.addEventListener("mouseleave", () => gsap.to(cursor, { scale: 1, backgroundColor: '#D4622A', border: 'none', duration: 0.3 }));
    });
  }
</script>
